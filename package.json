{
  "name": "kakeibo",
  "version": "0.0.1",
  "description": "个人记账软件 - 自定义账单周期，一级/二级分类，月度报告导出",
  "main": "./out/main/index.js",
  "author": "10MF01",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-clean-env.cjs electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && node scripts/run-clean-env.cjs electron-builder --win --x64",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\""
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.2",
    "@ant-design/plots": "^2.3.3",
    "antd": "^5.22.5",
    "better-sqlite3": "^11.7.0",
    "dayjs": "^1.11.13",
    "exceljs": "^4.4.0",
    "i18next": "^24.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
